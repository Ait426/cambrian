{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "name",
    "description",
    "domain",
    "tags",
    "mode",
    "runtime"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "author": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "mode": {
      "type": "string",
      "enum": ["a", "b"]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "needs_network",
        "needs_filesystem",
        "timeout_seconds"
      ],
      "properties": {
        "language": {
          "type": "string",
          "enum": ["python"]
        },
        "needs_network": {
          "type": "boolean"
        },
        "needs_filesystem": {
          "type": "boolean"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "fitness_score",
        "total_executions",
        "successful_executions",
        "last_used",
        "crystallized_at"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["active", "newborn", "dormant", "fossil"]
        },
        "fitness_score": {
          "type": "number"
        },
        "total_executions": {
          "type": "integer",
          "minimum": 0
        },
        "successful_executions": {
          "type": "integer",
          "minimum": 0
        },
        "last_used": {
          "type": ["string", "null"]
        },
        "crystallized_at": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
