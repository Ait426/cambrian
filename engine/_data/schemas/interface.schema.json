{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["input", "output"],
  "properties": {
    "input": { "$ref": "#/definitions/ioObject" },
    "output": { "$ref": "#/definitions/ioObject" }
  },
  "definitions": {
    "propertyDef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "description"],
      "properties": {
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string"
        }
      }
    },
    "ioObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "properties", "required"],
      "properties": {
        "type": {
          "type": "string",
          "const": "object"
        },
        "properties": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/propertyDef"
          }
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
